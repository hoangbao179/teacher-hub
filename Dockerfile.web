FROM node:24.18.0-alpine AS build
WORKDIR /app
RUN npm install -g npm@12.0.1
COPY package.json package-lock.json .npmrc ./
COPY shared/package.json shared/package.json
COPY server/package.json server/package.json
COPY client/package.json client/package.json
RUN npm ci
COPY shared shared
COPY client client

ARG VITE_API_BASE_URL=
ARG VITE_PUBLIC_ZALO_URL
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL \
    VITE_PUBLIC_ZALO_URL=$VITE_PUBLIC_ZALO_URL
RUN npm run build:shared && npm -w client run build:production

FROM nginxinc/nginx-unprivileged:1.27-alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/client/dist /usr/share/nginx/html
EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 CMD wget -q -O - http://127.0.0.1:8080/health || exit 1
