FROM node:24.18.0-alpine AS build
WORKDIR /app
RUN npm install -g npm@12.0.1
ARG VITE_API_BASE_URL=
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ARG VITE_PUBLIC_CONTENT_MODE
ARG VITE_PUBLIC_SITE_URL
ARG VITE_PUBLIC_TEACHER_NAME
ARG VITE_PUBLIC_BRAND_NAME
ARG VITE_PUBLIC_SUBJECT_LINE
ARG VITE_PUBLIC_DESCRIPTION
ARG VITE_PUBLIC_INTRODUCTION
ARG VITE_PUBLIC_ZALO_URL
ARG VITE_PUBLIC_PHONE_DISPLAY
ARG VITE_PUBLIC_PHONE_E164
ARG VITE_PUBLIC_FACEBOOK_URL
ARG VITE_PUBLIC_HERO_MOBILE_URL
ARG VITE_PUBLIC_HERO_DESKTOP_URL
ARG VITE_PUBLIC_VIDEOS_JSON
ARG VITE_PUBLIC_TESTIMONIALS_JSON
ARG VITE_PUBLIC_SEO_TITLE
ARG VITE_PUBLIC_SEO_DESCRIPTION
ENV VITE_PUBLIC_CONTENT_MODE=$VITE_PUBLIC_CONTENT_MODE \
    VITE_PUBLIC_SITE_URL=$VITE_PUBLIC_SITE_URL \
    VITE_PUBLIC_TEACHER_NAME=$VITE_PUBLIC_TEACHER_NAME \
    VITE_PUBLIC_BRAND_NAME=$VITE_PUBLIC_BRAND_NAME \
    VITE_PUBLIC_SUBJECT_LINE=$VITE_PUBLIC_SUBJECT_LINE \
    VITE_PUBLIC_DESCRIPTION=$VITE_PUBLIC_DESCRIPTION \
    VITE_PUBLIC_INTRODUCTION=$VITE_PUBLIC_INTRODUCTION \
    VITE_PUBLIC_ZALO_URL=$VITE_PUBLIC_ZALO_URL \
    VITE_PUBLIC_PHONE_DISPLAY=$VITE_PUBLIC_PHONE_DISPLAY \
    VITE_PUBLIC_PHONE_E164=$VITE_PUBLIC_PHONE_E164 \
    VITE_PUBLIC_FACEBOOK_URL=$VITE_PUBLIC_FACEBOOK_URL \
    VITE_PUBLIC_HERO_MOBILE_URL=$VITE_PUBLIC_HERO_MOBILE_URL \
    VITE_PUBLIC_HERO_DESKTOP_URL=$VITE_PUBLIC_HERO_DESKTOP_URL \
    VITE_PUBLIC_VIDEOS_JSON=$VITE_PUBLIC_VIDEOS_JSON \
    VITE_PUBLIC_TESTIMONIALS_JSON=$VITE_PUBLIC_TESTIMONIALS_JSON \
    VITE_PUBLIC_SEO_TITLE=$VITE_PUBLIC_SEO_TITLE \
    VITE_PUBLIC_SEO_DESCRIPTION=$VITE_PUBLIC_SEO_DESCRIPTION
COPY package.json package-lock.json .npmrc ./
COPY shared/package.json shared/package.json
COPY server/package.json server/package.json
COPY client/package.json client/package.json
RUN npm ci
COPY shared shared
COPY client client
RUN npm run build:shared && npm -w client run build:production

FROM nginxinc/nginx-unprivileged:1.27-alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/client/dist /usr/share/nginx/html
EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 CMD wget -q -O - http://127.0.0.1:8080/health || exit 1
