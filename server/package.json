{
  "name": "@teacher/server",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node scripts/copy-migrations.cjs",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:bootstrap-admin": "tsx src/db/bootstrap-admin.ts",
    "db:migrate:prod": "node dist/db/migrate.js"
  },
  "dependencies": {
    "@teacher/shared": "0.1.0",
    "bcryptjs": "3.0.3",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "helmet": "8.3.0",
    "jsonwebtoken": "9.0.3",
    "mysql2": "3.23.1"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "24.10.9",
    "tsx": "4.23.1",
    "typescript": "6.0.3"
  }
}
